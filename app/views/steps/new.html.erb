<div class="container">

    <div class="mascot-area">
      <div class="mascot">
        <%= image_tag "mayomayo.png", class: "mascot-img" %>
      </div>

      <div class="mascot-bubble">
        <div class="bubble-content-wrapper">
          <div class="bubble-main">
            <p class="bubble-title">
              まよまよステップへようこそ！
            </p>
            <p class="bubble-text">
              やること、もう迷わなくていい。<br>
              今日やる一歩を1つに決めます🌱
            </p>
           <p class="how-to-use">
              今の気持ちと、<br>やりたいことを入力するだけ。<br>
              まよまよが、今日の一歩を見つけます。
           </p>
          </div>
      

        <div class="bubble-examples">
          <p class="examples-intro">例えば、こんなこと：</p>
           <ul class="examples-simple-list">
               <li>料理がうまくなりたい</li>
               <li>栄養について勉強したい</li>
               <li>音楽を作ってみたい</li>
            </ul>
        </div>
      </div>
    </div>
  </div>
  
  <%= form_with url: generate_step_path, method: :post, scope: :step, local: true, class: "main-form" do |f| %>
    
    <% if @step.errors.any? %>
      <div class='alert alert-danger'>
        <ul>
          <% @step.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    
    <div class="form-group goal-group">
      <%= f.label :goal, class: 'form-label' do %>
         🌱気になっていること
          <span class="required-badge">必須</span>
      <% end %>

      <%= f.text_area :goal, 
          class: 'form-control',
          rows: 3, 
          placeholder: 'ここに書いてね', 
          'aria-required': 'true' %>
    </div>

     <div class="form-group">
        <%= f.label :feeling, class: 'form-label' do %>
          💭今どんな感じ？
          <span class="required-badge">必須</span>
        <% end %>
        <%= f.hidden_field :feeling, id: "feeling-field" %>
      
      <div class="status-buttons" data-target="feeling-field">
        <% Step::FEELINGS.each do |key, label| %>
          <button type="button" 
            class="status-btn <%= 'active' if @step.feeling == key %>"
            data-value="<%= key %>">
            <%= label %>
          </button>
        <% end %>
      </div>
    </div>
    
    <div class="form-group">
       <%= f.label :time_available, class: 'form-label' do %>
         ⌛一歩の大きさ
         <span class="required-badge">任意</span>
       <% end %>
       <%= f.hidden_field :time_available, id: "time-available-field" %>
      
      <div class="status-buttons" data-target="time-available-field">
        <% Step::TIME_AVAILABLE_OPTIONS.each do |key, label| %>
          <button type="button"
            class="status-btn <%= 'active' if @step.time_available == key %>"
            data-value="<%= key %>">
            <%= label %>
          </button>
        <% end %>
      </div>
    </div>

    <div class="form-actions">
      <%= f.submit 'まよまよに相談する', class: 'btn btn-primary' %>
    </div>

    <div id="loading-indicator" class="loading-indicator hidden">
      <div class="mayomayo-thinking">
        <%= image_tag "mayo-loading.png", class: "mayomayo-loading-img" %>
          <div class="thinking-animation">
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="dot"></span>
          </div>
      </div>
        <p class="loading-text">考え中...</p>
    </div>
  <% end %>
</div>
