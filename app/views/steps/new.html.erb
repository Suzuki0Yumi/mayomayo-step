<div class="container">
    <div class="header">
      まよまよステップ
    </div>

    <svg style="display:block; width:100%; height:28px; margin-top:-1px;"
       viewBox="0 0 480 28" preserveAspectRatio="none"
       xmlns="http://www.w3.org/2000/svg">
      <path d="M0,0 C40,0 40,24 80,24 C120,24 120,4 160,4 C200,4 200,24 240,24
           C280,24 280,4 320,4 C360,4 360,24 400,24 C440,24 440,4 480,4 L480,0 Z"
        fill="#e76f51"/>
    </svg>

    <div class="mascot-area">
      <div class="mascot">
        <%= image_tag "mayomayo.png", class: "mascot-img" %>
      </div>
      <div class="mascot-bubble">
        <p class="bubble-title">
          やりたい気持ちはあるのに、なかなか動けないときに
        </p>
        <p class="bubble-text">
         「今日これならできそう」と思える一歩を<br>まよまよが提案します。<br>
           小さなことでも大丈夫。一緒に考えよう🌱
        </p>
       </div>
    </div>
  
  <%= form_with url: generate_step_path, method: :post, scope: :step, local: true, class: "main-form" do |f| %>
    
    <% if @step.errors.any? %>
      <div class='alert alert-danger'>
        <ul>
          <% @step.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    
    
    <div class="form-group goal-group">
      <%= f.label :goal, class: 'form-label' do %>
         🌱気になっていること
          <span class="required-badge">(必須)</span>
      <% end %>

      <%= f.text_area :goal, 
          class: 'form-control',
          rows: 4, 
          placeholder: '例：英語やり直したい気がしてる、運動したほうがいいかなと思ってる、新しいことに少し興味ある', 
          'aria-required': 'true' %>
    </div>

     <div class="form-group">
        <%= f.label :feeling, class: 'form-label' do %>
          💭今の気持ち
          <span class="required-badge">(必須)</span>
        <% end %>
        <%= f.hidden_field :feeling, id: "feeling-field" %>
      
      <div class="status-buttons" data-target="feeling-field">
        <% Step::FEELINGS.each do |key, label| %>
          <button type="button" 
            class="status-btn <%= 'active' if @step.feeling == key %>"
            data-value="<%= key %>">
            <%= label %>
          </button>
        <% end %>
      </div>
    </div>
    
    <div class="form-group">
       <%= f.label :time_available, class: 'form-label' do %>
         ⌛今から使える時間
         <span class="required-badge">(必須)</span>
       <% end %>
       <%= f.hidden_field :time_available, id: "time-available-field" %>
      
      <div class="status-buttons" data-target="time-available-field">
        <% Step::TIME_AVAILABLE_OPTIONS.each do |key, label| %>
          <button type="button"
            class="status-btn <%= 'active' if @step.time_available == key %>"
            data-value="<%= key %>">
            <%= label %>
          </button>
        <% end %>
      </div>
    </div>

     <div class="form-group">
       <%= f.label :blocker, class: 'form-label' do %>
          🚧 もしあれば：何がちょっと邪魔してる？
       <% end %>
       <%= f.hidden_field :blocker, id: "blocker-field" %>
      
      <div class="status-buttons" data-target="blocker-field">
       <% Step::BLOCKERS.each do |key, label| %>
          <button type="button"
            class="status-btn <%= 'active' if @step.blocker == key %>"
            data-value="<%= key %>">
            <%= label %>
          </button>
        <% end %> 
      </div>
    </div>

    <div class="form-actions">
      <%= f.submit 'まよまよに相談する', class: 'btn btn-primary' %>
    </div>
  <% end %>
</div>
